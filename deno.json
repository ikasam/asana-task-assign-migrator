{
  "name": "@ikasam/asana-task-assign-migrator",
  "version": "0.2.1",
  "license": "MIT",
  "exports": "./src/main.ts",
  "tasks": {
    "migrate": "deno run --allow-net=app.asana.com --allow-env=ASANA_ACCESS_TOKEN --allow-read src/main.ts migrate",
    "survey": "deno run --allow-net=app.asana.com --allow-env=ASANA_ACCESS_TOKEN --allow-read src/main.ts survey",
    "dev": "deno run --allow-net --allow-env --allow-read src/main.ts",
    "test": "deno test --allow-env --allow-read --allow-run tests/",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "lint": "deno lint",
    "check": "deno check src/main.ts src/survey.ts",
    "notices": "deno install --node-modules-dir=auto --frozen && deno run --allow-read --allow-write scripts/gen_third_party_notices.ts",
    "spike:phase1": "deno run --allow-net --allow-env --allow-read spike/phase1_load.ts",
    "spike:phase2": "deno run --allow-net --allow-env --allow-read spike/phase2_api.ts"
  },
  "imports": {
    "asana": "npm:asana@3.1.11",
    "@std/assert": "jsr:@std/assert@1"
  },
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "lib": ["deno.window"]
  },
  "fmt": {
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": false,
    "include": ["src/", "tests/", "spike/", "scripts/"]
  },
  "lint": {
    "include": ["src/", "tests/", "spike/", "scripts/"],
    "rules": {
      "tags": ["recommended"]
    }
  }
}
