{
  "name": "@ikasam/asana-task-assign-migrator",
  "version": "0.1.0",
  "exports": "./src/main.ts",
  "tasks": {
    "migrate": "deno run --allow-net=app.asana.com --allow-env=ASANA_ACCESS_TOKEN --allow-read src/main.ts",
    "dev": "deno run --allow-net --allow-env --allow-read src/main.ts",
    "test": "deno test --allow-env --allow-read tests/",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "lint": "deno lint",
    "check": "deno check src/main.ts",
    "spike:phase1": "deno run --allow-net --allow-env --allow-read spike/phase1_load.ts",
    "spike:phase2": "deno run --allow-net --allow-env --allow-read spike/phase2_api.ts"
  },
  "imports": {
    "asana": "npm:asana@3.1.11",
    "@std/assert": "jsr:@std/assert@1",
    "@std/cli": "jsr:@std/cli@1",
    "@std/fmt": "jsr:@std/fmt@1"
  },
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "lib": ["deno.window"]
  },
  "fmt": {
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": false,
    "include": ["src/", "tests/", "spike/"]
  },
  "lint": {
    "include": ["src/", "tests/", "spike/"],
    "rules": {
      "tags": ["recommended"]
    }
  }
}
